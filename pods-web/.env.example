# Web istemcisi (Vite)
# Panel alt adreste ise (örn. https://site.com/pods/): sonunda / ile
# VITE_BASE=/pods/
# Aynı alt yol için public/.htaccess içinde RewriteBase /pods/ kullanın (yoksa ilk açılış 404 / boş sayfa).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Yeni anahtar (tercih) veya JWT anon — en az biri dolu olmalı
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role / secret API key — SADECE Supabase Dashboard → Edge Functions → Secrets
# (buraya VITE_ ile eklemeyin)
