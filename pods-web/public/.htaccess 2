# pods-web (Vite + React Router) — cPanel / Apache
# dist köküne kopyalanır; index.html ile aynı dizinde olmalı.
#
# ÖNEMLİ — Yönlendirme döngüsü (ERR_TOO_MANY_REDIRECTS):
# cPanel "Always HTTPS" aktifse burada tekrar HTTP→HTTPS RewriteRule eklemeyin.
#
# CORS: Statik SPA için kök alan ada "Access-Control-Allow-Origin *" eklenmedi —
# API istekleri supabase.co üzerinden gider; orası kendi CORS başlıklarını verir.

<IfModule mod_dir.c>
  DirectoryIndex index.html
</IfModule>

Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# ES modülü olarak .js yüklenmesi için doğru MIME
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType application/javascript .mjs
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_headers.c>
  # HTML: her zaman taze (hash’li asset isimleri zaten cache-bust)
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
  </FilesMatch>
  <FilesMatch "^(index\.html|\.htaccess)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
  </FilesMatch>
  # Vite hash’li varlıklar — tüm siteye no-store vermek performansı öldürür
  <FilesMatch "\.(js|mjs|css|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
